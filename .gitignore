*.iml

website/vendor

# Test exclusions
!command/test-fixtures/**/*.tfstate
!command/test-fixtures/**/.terraform/

# Keep windows files with windows line endings
*.winfile eol=crlf

# Down-converted spec produced transiently by `make generate`.
/api/openapi.gen.json

# Local Terraform CLI config for dev_overrides when testing examples.
dev.tfrc

# Terraform variable files often contain secrets.
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# All state files (any name / any dir), not just the default.
*.tfstate
*.tfstate.*

# Local env / secrets.
.env
.env.*
